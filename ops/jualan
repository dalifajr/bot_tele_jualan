#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BOT_SERVICE="jualan-bot.service"
API_SERVICE="jualan-api.service"

is_valid_project_dir() {
  local dir="$1"
  [[ -n "${dir}" && -f "${dir}/.env.example" && -f "${dir}/ops/update_manager.sh" && -f "${dir}/ops/jualan" ]]
}

resolve_project_dir() {
  local guessed
  guessed="$(cd "$(dirname "${SCRIPT_PATH}")/.." && pwd)"
  if is_valid_project_dir "${guessed}"; then
    echo "${guessed}"
    return
  fi

  local repo_top=""
  if repo_top="$(git -C "${PWD}" rev-parse --show-toplevel 2>/dev/null)"; then
    if is_valid_project_dir "${repo_top}"; then
      echo "${repo_top}"
      return
    fi
  fi

  local candidates=()
  if [[ -n "${JUALAN_PROJECT_DIR:-}" ]]; then
    candidates+=("${JUALAN_PROJECT_DIR}")
  fi
  candidates+=(
    "${PWD}"
    "${HOME}/bot_tele_jualan"
    "/root/bot_tele_jualan"
  )

  local candidate
  for candidate in "${candidates[@]}"; do
    if is_valid_project_dir "${candidate}"; then
      echo "${candidate}"
      return
    fi
  done

  echo "${guessed}"
}

PROJECT_DIR="$(resolve_project_dir)"
ENV_FILE="${PROJECT_DIR}/.env"
ROLE_FILE="${PROJECT_DIR}/user_role.txt"
UPDATE_SCRIPT="${PROJECT_DIR}/ops/update_manager.sh"
BACKUP_SCRIPT="${PROJECT_DIR}/ops/backup_manager.sh"
WEBSITE_SCRIPT="${PROJECT_DIR}/ops/website_installer.sh"

if [[ ! -x "${UPDATE_SCRIPT}" ]]; then
  chmod +x "${UPDATE_SCRIPT}" 2>/dev/null || true
fi
if [[ ! -x "${BACKUP_SCRIPT}" ]]; then
  chmod +x "${BACKUP_SCRIPT}" 2>/dev/null || true
fi
if [[ ! -x "${WEBSITE_SCRIPT}" ]]; then
  chmod +x "${WEBSITE_SCRIPT}" 2>/dev/null || true
fi

if ! is_valid_project_dir "${PROJECT_DIR}"; then
  echo "Struktur project tidak valid: ${PROJECT_DIR}" >&2
  echo "Solusi cepat:" >&2
  echo "1) cd ~/bot_tele_jualan" >&2
  echo "2) sudo ln -sf /root/bot_tele_jualan/ops/jualan /usr/local/bin/jualan" >&2
  echo "3) hash -r" >&2
  exit 1
fi

print_usage() {
  cat <<'EOF'
Usage: jualan <command>

Commands:
  start        Start bot and API service
  stop         Stop bot and API service
  restart      Restart bot and API service
  status       Show service status
  logs         Show bot logs (follow)
  config       Configure BOT_TOKEN, LISTENER_SHARED_SECRET, and admin id
  update       Apply update from GitHub
  check-update Check latest commit from GitHub
  rollback     Rollback to previous commit
  backup       Create database backup snapshot now
  list-backups List existing backup snapshots
  restore-backup [file]
              Restore DB from backup file (default: latest)
  prune-backups [keep]
               Keep latest N backups (default from BACKUP_KEEP_COUNT or 14)
  install-website [domain]
               Install Laravel website (PHP, Nginx, SSL)
  website-status Show website service status
  website-restart Restart website services (PHP-FPM + Nginx)
  website-logs   Show website logs
  website-domain [domain]
               Configure/change website domain + SSL
  turnstile-config
               Configure Cloudflare Turnstile captcha keys for website
  uninstall    Stop/disable services and remove alias
EOF
}

set_env_var() {
  local key="$1"
  local value="$2"
  local escaped
  escaped="${value//|/\\|}"
  escaped="${escaped//&/\\&}"

  if [[ ! -f "${ENV_FILE}" ]]; then
    cp "${PROJECT_DIR}/.env.example" "${ENV_FILE}"
  fi

  if grep -q "^${key}=" "${ENV_FILE}"; then
    sed -i "s|^${key}=.*|${key}=${escaped}|" "${ENV_FILE}"
  else
    printf '%s=%s\n' "${key}" "${value}" >> "${ENV_FILE}"
  fi
}

configure_admin_role() {
  local admin_id="$1"
  if [[ -z "${admin_id}" ]]; then
    return
  fi

  if [[ ! "${admin_id}" =~ ^[0-9]+$ ]]; then
    echo "Admin ID harus angka." >&2
    exit 1
  fi

  cat > "${ROLE_FILE}" <<EOF
# Format: admin:<telegram_user_id>
# Dikelola oleh panel jualan
admin:${admin_id}
EOF
}

start_services() {
  sudo systemctl start "${BOT_SERVICE}" "${API_SERVICE}"
  echo "Service started."
}

stop_services() {
  sudo systemctl stop "${BOT_SERVICE}" "${API_SERVICE}"
  echo "Service stopped."
}

restart_services() {
  sudo systemctl restart "${BOT_SERVICE}" "${API_SERVICE}"
  echo "Service restarted."
}

status_services() {
  sudo systemctl --no-pager --full status "${BOT_SERVICE}" "${API_SERVICE}" || true
}

show_logs() {
  sudo journalctl -u "${BOT_SERVICE}" -f
}

configure_bot() {
  local token secret admin_id
  read -r -p "BOT_TOKEN: " token
  read -r -p "LISTENER_SHARED_SECRET (kosongkan untuk skip): " secret
  read -r -p "Admin Telegram ID (kosongkan untuk skip): " admin_id

  if [[ -n "${token}" ]]; then
    set_env_var "BOT_TOKEN" "${token}"
  fi

  if [[ -n "${secret}" ]]; then
    set_env_var "LISTENER_SHARED_SECRET" "${secret}"
  fi

  configure_admin_role "${admin_id}"
  echo "Konfigurasi tersimpan. Restart service agar perubahan aktif."
}

apply_update() {
  bash "${UPDATE_SCRIPT}" update
}

check_update() {
  bash "${UPDATE_SCRIPT}" check
}

rollback_update() {
  bash "${UPDATE_SCRIPT}" rollback
}

backup_now() {
  bash "${BACKUP_SCRIPT}" backup
}

list_backups_cmd() {
  bash "${BACKUP_SCRIPT}" list
}

restore_backup_cmd() {
  bash "${BACKUP_SCRIPT}" restore "${1:-}"
}

prune_backups_cmd() {
  bash "${BACKUP_SCRIPT}" prune "${1:-}"
}

install_website_cmd() {
  sudo bash "${WEBSITE_SCRIPT}" install "${1:-}"
}

website_status_cmd() {
  bash "${WEBSITE_SCRIPT}" status
}

website_restart_cmd() {
  sudo bash "${WEBSITE_SCRIPT}" restart
}

website_logs_cmd() {
  bash "${WEBSITE_SCRIPT}" logs
}

website_domain_cmd() {
  sudo bash "${WEBSITE_SCRIPT}" configure-domain "${1:-}"
}

configure_turnstile() {
  local WEB_ENV="${PROJECT_DIR}/web/.env"
  if [[ ! -f "${WEB_ENV}" ]]; then
    echo "File web/.env tidak ditemukan. Jalankan 'jualan install-website' terlebih dahulu." >&2
    exit 1
  fi

  echo "=== Konfigurasi Cloudflare Turnstile ==="
  echo "Dapatkan key dari: https://dash.cloudflare.com/turnstile"
  echo ""

  local site_key secret_key
  read -r -p "Turnstile Site Key: " site_key
  read -r -p "Turnstile Secret Key: " secret_key

  if [[ -z "${site_key}" || -z "${secret_key}" ]]; then
    echo "Kedua key harus diisi. Batal." >&2
    exit 1
  fi

  # Update or append to web/.env
  if grep -q "^CLOUDFLARE_TURNSTILE_SITE_KEY=" "${WEB_ENV}"; then
    sed -i "s|^CLOUDFLARE_TURNSTILE_SITE_KEY=.*|CLOUDFLARE_TURNSTILE_SITE_KEY=${site_key}|" "${WEB_ENV}"
  else
    printf '\nCLOUDFLARE_TURNSTILE_SITE_KEY=%s\n' "${site_key}" >> "${WEB_ENV}"
  fi

  if grep -q "^CLOUDFLARE_TURNSTILE_SECRET_KEY=" "${WEB_ENV}"; then
    sed -i "s|^CLOUDFLARE_TURNSTILE_SECRET_KEY=.*|CLOUDFLARE_TURNSTILE_SECRET_KEY=${secret_key}|" "${WEB_ENV}"
  else
    printf 'CLOUDFLARE_TURNSTILE_SECRET_KEY=%s\n' "${secret_key}" >> "${WEB_ENV}"
  fi

  echo ""
  echo "Turnstile key berhasil disimpan ke web/.env"
  echo "Restart website agar perubahan aktif: jualan website-restart"
}

uninstall_bot() {
  local confirm
  read -r -p "Yakin uninstall bot service? ketik YES: " confirm
  if [[ "${confirm}" != "YES" ]]; then
    echo "Batal."
    exit 0
  fi

  sudo systemctl stop "${BOT_SERVICE}" "${API_SERVICE}" || true
  sudo systemctl disable "${BOT_SERVICE}" "${API_SERVICE}" || true
  sudo rm -f "/etc/systemd/system/${BOT_SERVICE}" "/etc/systemd/system/${API_SERVICE}"
  sudo systemctl daemon-reload
  sudo rm -f /usr/local/bin/jualan

  echo "Uninstall selesai (kode project tidak dihapus)."
}

menu() {
  cat <<'EOF'
Panel Jualan
1) start
2) stop
3) restart
4) status
5) config
6) check-update
7) update
8) rollback
9) backup
10) list-backups
11) restore-backup (latest)
12) prune-backups
13) install-website
14) website-status
15) website-restart
16) website-logs
17) website-domain
18) turnstile-config
19) uninstall-website
20) uninstall bot service
0) keluar
EOF
  read -r -p "Pilih menu: " choice
  case "${choice}" in
    1) start_services ;;
    2) stop_services ;;
    3) restart_services ;;
    4) status_services ;;
    5) configure_bot ;;
    6) check_update ;;
    7) apply_update ;;
    8) rollback_update ;;
    9) backup_now ;;
    10) list_backups_cmd ;;
    11) restore_backup_cmd ;;
    12) prune_backups_cmd ;;
    13) install_website_cmd ;;
    14) website_status_cmd ;;
    15) website_restart_cmd ;;
    16) website_logs_cmd ;;
    17) website_domain_cmd ;;
    18) configure_turnstile ;;
    19) sudo bash "${WEBSITE_SCRIPT}" uninstall ;;
    20) uninstall_bot ;;
    0) exit 0 ;;
    *) echo "Pilihan tidak valid." ;;
  esac
}

cmd="${1:-}"
case "${cmd}" in
  start) start_services ;;
  stop) stop_services ;;
  restart) restart_services ;;
  status) status_services ;;
  logs) show_logs ;;
  config) configure_bot ;;
  update) apply_update ;;
  check-update) check_update ;;
  rollback) rollback_update ;;
  backup) backup_now ;;
  list-backups) list_backups_cmd ;;
  restore-backup) restore_backup_cmd "${2:-}" ;;
  prune-backups) prune_backups_cmd "${2:-}" ;;
  install-website) install_website_cmd "${2:-}" ;;
  website-status) website_status_cmd ;;
  website-restart) website_restart_cmd ;;
  website-logs) website_logs_cmd ;;
  website-domain) website_domain_cmd "${2:-}" ;;
  turnstile-config) configure_turnstile ;;
  uninstall-website) sudo bash "${WEBSITE_SCRIPT}" uninstall ;;
  uninstall) uninstall_bot ;;
  "") menu ;;
  *) print_usage; exit 1 ;;
esac
